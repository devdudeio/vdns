{
  "name": "vdns",
  "version": "0.2.2",
  "description": "VerusID-native local DNS and web gateway",
  "type": "module",
  "private": false,
  "bin": {
    "vdns": "./bin/vdns"
  },
  "license": "MIT",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "dev:rpc": "tsx watch src/index.ts",
    "dev:mock": "cross-env VDNS_MODE=mock tsx watch src/index.ts",
    "redirect:dev": "tsx watch src/redirect-index.ts",
    "start": "node dist/index.js",
    "start:rpc": "node dist/index.js",
    "start:mock": "cross-env VDNS_MODE=mock node dist/index.js",
    "redirect:start": "node dist/redirect-index.js",
    "test": "vitest run",
    "macos:vdns:diagnose": "scripts/macos/diagnose-vdns.sh",
    "macos:vdns:test": "scripts/macos/test-chainvue-redirect.sh",
    "vdns:up": "scripts/macos/vdns-up.sh",
    "vdns:down": "scripts/macos/vdns-down.sh",
    "vdns:status": "scripts/macos/vdns-status.sh",
    "vdns:doctor": "bin/vdns doctor",
    "vdns:demo": "scripts/macos/vdns-demo.sh",
    "vdns:terminal-demo": "scripts/macos/vdns-terminal-demo.sh",
    "vdns:install": "scripts/macos/install-services.sh",
    "vdns:uninstall": "scripts/macos/uninstall-services.sh",
    "vdns:start": "scripts/macos/start-services.sh",
    "vdns:stop": "scripts/macos/stop-services.sh",
    "vdns:restart": "scripts/macos/restart-services.sh",
    "vdns:service-status": "scripts/macos/print-service-status.sh",
    "macos:redirect:start80": "sudo scripts/macos/start-redirect-port80.sh",
    "macos:redirect:stop80": "sudo scripts/macos/stop-redirect-port80.sh",
    "macos:resolver:install": "sudo scripts/macos/install-vdns-resolver.sh",
    "macos:resolver:uninstall": "sudo scripts/macos/uninstall-vdns-resolver.sh",
    "macos:resolver:status": "scripts/macos/status-vdns-resolver.sh"
  },
  "dependencies": {
    "@fastify/sensible": "^6.0.3",
    "commander": "^14.0.3",
    "dotenv": "^17.4.2",
    "fastify": "^5.6.2",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "cross-env": "^10.1.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.23.0"
}
